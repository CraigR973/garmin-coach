# =============================================================================
# Garmin Coach — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Postgres connection string for SQLAlchemy (asyncpg driver)
# Format: postgresql+asyncpg://user:password@host:port/dbname
# Supabase on Railway: use the session-mode pooler, port 5432.
# Do not use the direct db.* host from Railway (IPv6/IPv4 mismatch), and do not
# use transaction mode / port 6543 with asyncpg prepared statements.
#   postgresql+asyncpg://postgres.<project-ref>:<password>@aws-1-eu-north-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/garmin_coach

# -----------------------------------------------------------------------------
# Supabase (optional — only needed if using Supabase client directly)
# -----------------------------------------------------------------------------

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------

# Secret for signing access tokens (HS256, 24h TTL) — min 32 random chars
JWT_ACCESS_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Secret for signing refresh tokens (30d TTL) — min 32 random chars
JWT_REFRESH_SECRET=change-me-to-another-random-secret-at-least-32-chars

# -----------------------------------------------------------------------------
# Web Push (VAPID)
# -----------------------------------------------------------------------------

# VAPID public key — used by backend to sign push requests
VAPID_PUBLIC_KEY=your-vapid-public-key

# VAPID public key — VITE_ prefix exposes it to the React frontend for push subscription
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# VAPID private key — backend only
VAPID_PRIVATE_KEY=your-vapid-private-key

# Contact email for VAPID (shown to push services)
VAPID_CONTACT_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# Allowed CORS origin for the backend (Vercel frontend URL in prod)
FRONTEND_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Frontend API wiring
# -----------------------------------------------------------------------------

# Local dev: point Vite at the local FastAPI server.
# Production Vercel: set VITE_API_URL to an empty string so the app calls
# same-origin /api/* routes, which are proxied to Railway by vercel.json.
VITE_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# External Data Sources
# -----------------------------------------------------------------------------

# Garmin Connect credentials. Do not commit real values.
# garminconnect persists OAuth tokens under GARMIN_TOKENSTORE after login; the
# password itself is not written by the app.
GARMIN_EMAIL=your-garmin-email
GARMIN_PASSWORD=your-garmin-password
GARMIN_TOKENSTORE=~/.garminconnect
# Optional secret-backed token blob for hosted deployments where the filesystem
# tokenstore is ephemeral. Generate with scripts/bootstrap_garmin_tokenstore.py.
GARMIN_TOKENSTORE_B64=

# Hive credentials. Do not commit real values.
HIVE_EMAIL=your-hive-email
HIVE_PASSWORD=your-hive-password
# Hive uses AWS Cognito SMS_MFA, so password login cannot run headlessly. Seed
# this base64 {username, refresh_token} blob once via a SMS-2FA login with
# scripts/bootstrap_hive_tokenstore.py; the poller then resumes unattended.
HIVE_TOKENSTORE_B64=

# Open-Meteo defaults for Kilmarnock (KA1 2SD).
WEATHER_LATITUDE=55.6045
WEATHER_LONGITUDE=-4.5249
WEATHER_TIMEZONE=Europe/London

# Anthropic API key — used by analysis engine
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1600

# intervals.icu delivery rail — output only, used to push approved structured
# workouts into the intervals.icu calendar that syncs to Zwift.
INTERVALS_API_KEY=your-intervals-api-key
INTERVALS_ATHLETE_ID=i618709
INTERVALS_BASE_URL=https://intervals.icu/api/v1

# -----------------------------------------------------------------------------
# Error Tracking (Sentry) — optional
# -----------------------------------------------------------------------------

SENTRY_DSN_BACKEND=
VITE_SENTRY_DSN=

# -----------------------------------------------------------------------------
# CI / Tooling
# -----------------------------------------------------------------------------

# GitHub personal access token — used by phase close-out to poll CI status
GITHUB_TOKEN=your-github-personal-access-token
